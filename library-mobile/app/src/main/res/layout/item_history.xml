<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Row 1: Cover + Info + Delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Cover -->
            <androidx.cardview.widget.CardView
                android:layout_width="72dp"
                android:layout_height="100dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="6dp">

                <ImageView
                    android:id="@+id/iv_cover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/placeholder_cover"/>
            </androidx.cardview.widget.CardView>

            <!-- Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <!-- Title + Status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/on_background"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:lineSpacingMultiplier="1.2"
                        tools:text="Tên truyện dài dài"/>

                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_background"
                        tools:text="Đang ra"
                        tools:background="@drawable/bg_badge_ongoing"/>
                </LinearLayout>

                <!-- Author -->
                <TextView
                    android:id="@+id/tv_author"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:layout_marginTop="3dp"
                    tools:text="Tác giả ABC"/>

                <!-- Đang đọc: Chương X -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:id="@+id/tv_last_chapter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Đang đọc: Chương 42"/>

                    <TextView
                        android:id="@+id/tv_total_chapters"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface_dim"
                        android:textSize="12sp"
                        android:layout_marginStart="4dp"
                        tools:text="/ 128 chương"/>
                </LinearLayout>

                <!-- Chapter title -->
                <TextView
                    android:id="@+id/tv_chapter_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface_dim"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp"
                    tools:text="Khởi đầu của cuộc hành trình"/>

                <!-- Last read time -->
                <TextView
                    android:id="@+id/tv_last_read"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface_dim"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:drawablePadding="4dp"
                    android:drawableTint="@color/on_surface_dim"
                    tools:text="2 giờ trước"/>
            </LinearLayout>

            <!-- Delete button -->
            <ImageButton
                android:id="@+id/btn_delete"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="top"
                android:src="@drawable/ic_close"
                app:tint="@color/on_surface_dim"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Xóa lịch sử"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Row 2: Progress bar + Continue button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <!-- Progress section -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Vị trí đọc"
                        android:textColor="@color/on_surface_dim"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tv_scroll_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="65%"/>
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_reading"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    app:trackColor="@color/divider"
                    app:indicatorColor="@color/primary"
                    app:trackCornerRadius="3dp"/>
            </LinearLayout>

            <!-- Continue reading button -->
            <Button
                android:id="@+id/btn_continue"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="▶ Đọc tiếp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/on_background"
                android:background="@drawable/bg_button_primary"
                android:paddingHorizontal="14dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>