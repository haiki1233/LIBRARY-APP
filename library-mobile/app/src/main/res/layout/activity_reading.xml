<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/reading_bg_dark">

    <!-- ===== TOP TOOLBAR (ẩn/hiện khi tap) ===== -->
    <LinearLayout
        android:id="@+id/toolbar_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/reading_toolbar_bg"
        android:paddingHorizontal="4dp"
        android:paddingTop="44dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            app:tint="@color/on_background"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginHorizontal="4dp">

            <TextView
                android:id="@+id/tv_story_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_background"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Tên truyện dài dài dài"/>

            <TextView
                android:id="@+id/tv_chapter_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_dim"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Chương 1: Khởi đầu"/>
        </LinearLayout>

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_settings"
            app:tint="@color/on_background"
            android:background="?attr/selectableItemBackgroundBorderless"/>

    </LinearLayout>

    <!-- ===== MAIN CONTENT (Image mode + Text mode) ===== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ── IMAGE MODE ── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_images"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:visibility="visible"/>

        <!-- ── TEXT MODE ── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Text content padding top = toolbar height -->
                <TextView
                    android:id="@+id/tv_chapter_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="80dp"
                    android:paddingBottom="120dp"
                    android:textSize="16sp"
                    android:lineSpacingMultiplier="1.6"
                    tools:text="Nội dung chapter text ở đây..."/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── LOADING ── -->
        <LinearLayout
            android:id="@+id/layout_loading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="@color/primary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/loading_chapter"
                android:textColor="@color/on_surface_dim"
                android:textSize="14sp"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- ── ERROR ── -->
        <LinearLayout
            android:id="@+id/layout_error"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/emoji_error"
                android:textSize="48sp"/>

            <TextView
                android:id="@+id/tv_error_msg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_dim"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginTop="12dp"/>

            <Button
                android:id="@+id/btn_retry"
                style="@style/Widget.TruyenHay.Button.Primary"
                android:layout_width="140dp"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:text="@string/retry"/>
        </LinearLayout>

    </FrameLayout>

    <!-- ===== BOTTOM NAVIGATION BAR (ẩn/hiện khi tap) ===== -->
    <LinearLayout
        android:id="@+id/toolbar_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/reading_toolbar_bg"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="28dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <!-- Chương trước -->
        <Button
            android:id="@+id/btn_prev_chapter"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/btn_prev_chapter"
            android:textColor="@color/on_surface_dim"
            android:textSize="13sp"
            android:background="@drawable/bg_nav_button"
            android:paddingHorizontal="12dp"/>

        <!-- Progress / trang hiện tại -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="8dp">

            <TextView
                android:id="@+id/tv_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_dim"
                android:textSize="12sp"
                tools:text="Trang 5 / 20"/>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_reading"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="4dp"
                app:trackColor="@color/divider"
                app:indicatorColor="@color/primary"
                app:trackCornerRadius="2dp"/>
        </LinearLayout>

        <!-- Chương sau -->
        <Button
            android:id="@+id/btn_next_chapter"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/btn_next_chapter"
            android:textColor="@color/on_background"
            android:textSize="13sp"
            android:background="@drawable/bg_button_primary"
            android:paddingHorizontal="12dp"/>

    </LinearLayout>

    <!-- ===== SETTINGS PANEL (slide từ dưới lên) ===== -->
    <LinearLayout
        android:id="@+id/panel_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_settings_panel"
        android:padding="20dp"
        android:paddingBottom="36dp"
        android:elevation="16dp"
        android:visibility="gone">

        <!-- Handle bar -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_handle_bar"
            android:layout_marginBottom="16dp"/>

        <!-- ── READ MODE TOGGLE ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/read_mode"
            android:textColor="@color/on_surface_dim"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:background="@color/surface_light"
            android:padding="4dp"
            android:gravity="center">

            <!-- Mode ảnh -->
            <TextView
                android:id="@+id/btn_mode_image"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/mode_image"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_mode_selected"/>

            <!-- Mode text -->
            <TextView
                android:id="@+id/btn_mode_text"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/mode_text"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="@color/on_surface_dim"
                android:background="@android:color/transparent"/>
        </LinearLayout>

        <!-- ── DARK MODE ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/dark_mode"
                android:textColor="@color/on_background"
                android:textSize="15sp"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_dark_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:thumbTint="@color/primary"
                app:trackTint="@color/primary_light"/>
        </LinearLayout>

        <!-- ── FONT SIZE (chỉ hiện ở text mode) ── -->
        <LinearLayout
            android:id="@+id/layout_font_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:visibility="gone">

            <!-- Font size -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/font_size"
                    android:textColor="@color/on_background"
                    android:textSize="15sp"/>

                <ImageButton
                    android:id="@+id/btn_font_decrease"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_remove"
                    app:tint="@color/on_background"
                    android:background="@drawable/bg_icon_button"/>

                <TextView
                    android:id="@+id/tv_font_size"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/on_background"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="16"/>

                <ImageButton
                    android:id="@+id/btn_font_increase"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_add"
                    app:tint="@color/on_background"
                    android:background="@drawable/bg_icon_button"/>
            </LinearLayout>

            <!-- Line spacing -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/line_spacing"
                    android:textColor="@color/on_background"
                    android:textSize="15sp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/btn_spacing_compact"
                        android:layout_width="44dp" android:layout_height="32dp"
                        android:text="≡" android:gravity="center" android:textSize="18sp"
                        android:textColor="@color/on_surface_dim"
                        android:background="@drawable/bg_spacing_btn"/>

                    <TextView android:id="@+id/btn_spacing_normal"
                        android:layout_width="44dp" android:layout_height="32dp"
                        android:text="☰" android:gravity="center" android:textSize="16sp"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_spacing_btn_selected"
                        android:layout_marginHorizontal="6dp"/>

                    <TextView android:id="@+id/btn_spacing_wide"
                        android:layout_width="44dp" android:layout_height="32dp"
                        android:text="⇕" android:gravity="center" android:textSize="16sp"
                        android:textColor="@color/on_surface_dim"
                        android:background="@drawable/bg_spacing_btn"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Font family -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/font_family"
                    android:textColor="@color/on_background"
                    android:textSize="15sp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/btn_font_default"
                        android:layout_width="56dp" android:layout_height="32dp"
                        android:text="Sans" android:gravity="center" android:textSize="12sp"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_spacing_btn_selected"/>

                    <TextView android:id="@+id/btn_font_serif"
                        android:layout_width="56dp" android:layout_height="32dp"
                        android:text="Serif" android:gravity="center" android:textSize="12sp"
                        android:fontFamily="serif"
                        android:textColor="@color/on_surface_dim"
                        android:background="@drawable/bg_spacing_btn"
                        android:layout_marginHorizontal="6dp"/>

                    <TextView android:id="@+id/btn_font_mono"
                        android:layout_width="56dp" android:layout_height="32dp"
                        android:text="Mono" android:gravity="center" android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:textColor="@color/on_surface_dim"
                        android:background="@drawable/bg_spacing_btn"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Dim overlay khi settings mở -->
    <View
        android:id="@+id/dim_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>