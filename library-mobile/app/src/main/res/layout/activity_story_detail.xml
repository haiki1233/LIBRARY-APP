<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:ignore="Spelling"> <!-- Bỏ qua lỗi chính tả tiếng Việt -->

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="@color/background"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/background"
            app:statusBarScrim="@color/background"
            app:titleEnabled="false">

            <ImageView
                android:id="@+id/iv_cover_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:alpha="0.35"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.6"
                android:contentDescription="@null"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_detail_overlay"
                app:layout_collapseMode="parallax"/>

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="8dp"
                    android:baselineAligned="false">

                    <ImageButton
                        android:id="@+id/btn_back"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_back"
                        app:tint="@color/on_background"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/desc_back"/>

                    <View android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>

                    <ImageButton
                        android:id="@+id/btn_favorite"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_favorite_border"
                        app:tint="@color/on_background"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/desc_favorite"/>

                    <ImageButton
                        android:id="@+id/btn_share"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_share"
                        app:tint="@color/on_background"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_marginStart="4dp"
                        android:contentDescription="@string/desc_share"/>
                </LinearLayout>
            </androidx.appcompat.widget.Toolbar>

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:baselineAligned="false">

                <androidx.cardview.widget.CardView
                    android:layout_width="110dp"
                    android:layout_height="155dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="12dp">

                    <ImageView
                        android:id="@+id/iv_cover"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="@null"
                        tools:src="@drawable/placeholder_cover"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/tv_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_background"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.2"
                        tools:text="Tên truyện rất dài"/>

                    <TextView
                        android:id="@+id/tv_author"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:layout_marginTop="6dp"
                        tools:text="Tác giả ABC"/>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_genres"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:chipSpacingVertical="4dp"
                        app:chipSpacingHorizontal="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_background"
                            tools:text="Đang ra"
                            tools:background="@drawable/bg_badge_ongoing"/>

                        <TextView
                            android:id="@+id/tv_chapters"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/on_surface_dim"
                            android:textSize="12sp"
                            android:layout_marginStart="8dp"
                            tools:text="128 chương"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_views"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface_dim"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        tools:text="👁 1.2M lượt xem"/>
                </LinearLayout>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_avg_score"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/on_background"
                                android:textSize="40sp"
                                android:textStyle="bold"
                                tools:text="4.5"/>

                            <TextView
                                android:id="@+id/tv_stars_display"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="16sp"
                                tools:text="⭐⭐⭐⭐⭐"/>

                            <TextView
                                android:id="@+id/tv_total_ratings"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/on_surface_dim"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"
                                tools:text="1.2K đánh giá"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_distribution"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">
                                <TextView android:layout_width="16dp" android:layout_height="wrap_content"
                                    android:text="@string/num_5" android:textColor="@color/on_surface_dim" android:textSize="11sp"/>
                                <com.google.android.material.progressindicator.LinearProgressIndicator
                                    android:id="@+id/bar_5star"
                                    android:layout_width="0dp" android:layout_height="6dp"
                                    android:layout_weight="1" android:layout_marginHorizontal="6dp"
                                    app:trackColor="@color/divider" app:indicatorColor="@color/primary"
                                    app:trackCornerRadius="3dp"/>
                                <TextView android:id="@+id/tv_5star_count"
                                    android:layout_width="24dp" android:layout_height="wrap_content"
                                    android:textColor="@color/on_surface_dim" android:textSize="11sp"
                                    tools:text="80"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">
                                <TextView android:layout_width="16dp" android:layout_height="wrap_content"
                                    android:text="@string/num_4" android:textColor="@color/on_surface_dim" android:textSize="11sp"/>
                                <com.google.android.material.progressindicator.LinearProgressIndicator
                                    android:id="@+id/bar_4star"
                                    android:layout_width="0dp" android:layout_height="6dp"
                                    android:layout_weight="1" android:layout_marginHorizontal="6dp"
                                    app:trackColor="@color/divider" app:indicatorColor="@color/primary"
                                    app:trackCornerRadius="3dp"/>
                                <TextView android:id="@+id/tv_4star_count"
                                    android:layout_width="24dp" android:layout_height="wrap_content"
                                    android:textColor="@color/on_surface_dim" android:textSize="11sp"
                                    tools:text="30"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">
                                <TextView android:layout_width="16dp" android:layout_height="wrap_content"
                                    android:text="@string/num_3" android:textColor="@color/on_surface_dim" android:textSize="11sp"/>
                                <com.google.android.material.progressindicator.LinearProgressIndicator
                                    android:id="@+id/bar_3star"
                                    android:layout_width="0dp" android:layout_height="6dp"
                                    android:layout_weight="1" android:layout_marginHorizontal="6dp"
                                    app:trackColor="@color/divider" app:indicatorColor="@color/primary"
                                    app:trackCornerRadius="3dp"/>
                                <TextView android:id="@+id/tv_3star_count"
                                    android:layout_width="24dp" android:layout_height="wrap_content"
                                    android:textColor="@color/on_surface_dim" android:textSize="11sp"
                                    tools:text="30"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">
                                <TextView android:layout_width="16dp" android:layout_height="wrap_content"
                                    android:text="@string/num_2" android:textColor="@color/on_surface_dim" android:textSize="11sp"/>
                                <com.google.android.material.progressindicator.LinearProgressIndicator
                                    android:id="@+id/bar_2star"
                                    android:layout_width="0dp" android:layout_height="6dp"
                                    android:layout_weight="1" android:layout_marginHorizontal="6dp"
                                    app:trackColor="@color/divider" app:indicatorColor="@color/primary"
                                    app:trackCornerRadius="3dp"/>
                                <TextView android:id="@+id/tv_2star_count"
                                    android:layout_width="24dp" android:layout_height="wrap_content"
                                    android:textColor="@color/on_surface_dim" android:textSize="11sp"
                                    tools:text="30"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">
                                <TextView android:layout_width="16dp" android:layout_height="wrap_content"
                                    android:text="@string/num_1" android:textColor="@color/on_surface_dim" android:textSize="11sp"/>
                                <com.google.android.material.progressindicator.LinearProgressIndicator
                                    android:id="@+id/bar_1star"
                                    android:layout_width="0dp" android:layout_height="6dp"
                                    android:layout_weight="1" android:layout_marginHorizontal="6dp"
                                    app:trackColor="@color/divider" app:indicatorColor="@color/primary"
                                    app:trackCornerRadius="3dp"/>
                                <TextView android:id="@+id/tv_1star_count"
                                    android:layout_width="24dp" android:layout_height="wrap_content"
                                    android:textColor="@color/on_surface_dim" android:textSize="11sp"
                                    tools:text="30"/>
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_your_rating"
                            android:textColor="@color/on_surface_dim"
                            android:textSize="13sp"/>

                        <LinearLayout
                            android:id="@+id/layout_my_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">

                            <ImageButton android:id="@+id/btn_star_1"
                                android:layout_width="36dp" android:layout_height="36dp"
                                android:src="@drawable/ic_star_border"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="@color/on_surface_dim"
                                android:contentDescription="@string/desc_star"/>

                            <ImageButton android:id="@+id/btn_star_2"
                                android:layout_width="36dp" android:layout_height="36dp"
                                android:src="@drawable/ic_star_border"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="@color/on_surface_dim"
                                android:contentDescription="@string/desc_star"/>

                            <ImageButton android:id="@+id/btn_star_3"
                                android:layout_width="36dp" android:layout_height="36dp"
                                android:src="@drawable/ic_star_border"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="@color/on_surface_dim"
                                android:contentDescription="@string/desc_star"/>

                            <ImageButton android:id="@+id/btn_star_4"
                                android:layout_width="36dp" android:layout_height="36dp"
                                android:src="@drawable/ic_star_border"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="@color/on_surface_dim"
                                android:contentDescription="@string/desc_star"/>

                            <ImageButton android:id="@+id/btn_star_5"
                                android:layout_width="36dp" android:layout_height="36dp"
                                android:src="@drawable/ic_star_border"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="@color/on_surface_dim"
                                android:contentDescription="@string/desc_star"/>

                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_introduction"
                    android:textColor="@color/on_background"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.6"
                    android:layout_marginTop="8dp"
                    android:maxLines="4"
                    android:ellipsize="end"
                    tools:text="Mô tả truyện..."/>

                <TextView
                    android:id="@+id/tv_expand_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_expand"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/title_chapter_list"
                        android:textColor="@color/on_background"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <ImageButton
                        android:id="@+id/btn_sort_chapters"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_sort"
                        app:tint="@color/on_surface_dim"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/desc_sort"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_chapters"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="12dp"
                    android:clipToPadding="false"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:paddingBottom="24dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <Button
            android:id="@+id/btn_read_first"
            style="@style/Widget.TruyenHay.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="@string/btn_read_now"/>

        <Button
            android:id="@+id/btn_continue_read"
            style="@style/Widget.TruyenHay.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/btn_continue_reading"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- ===== LOADING OVERLAY ===== -->
    <LinearLayout
        android:id="@+id/layout_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/background"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/primary"/>
    </LinearLayout>

    <!-- ===== ERROR STATE ===== -->
    <LinearLayout
        android:id="@+id/layout_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="@color/background"
        android:visibility="gone">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/emoji_error" android:textSize="56sp"/>

        <TextView android:id="@+id/tv_error_msg"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/on_surface_dim" android:textSize="15sp"
            android:gravity="center" android:layout_marginTop="16dp"/>

        <Button android:id="@+id/btn_retry"
            style="@style/Widget.TruyenHay.Button.Primary"
            android:layout_width="140dp" android:layout_height="48dp"
            android:layout_marginTop="20dp" android:text="@string/retry"/>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>