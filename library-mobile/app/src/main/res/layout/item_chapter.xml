<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground">

    <!-- Phần nội dung chính -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:baselineAligned="false"> <!-- Tối ưu hiệu suất -->

        <!-- Chapter number + title -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_chapter_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="Chương 1"/>

                <TextView
                    android:id="@+id/tv_continue_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_reading"
                    android:textColor="@color/primary"
                    android:textSize="11sp"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"
                    tools:visibility="visible"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_chapter_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_dim"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"
                tools:text="Khởi đầu của hành trình"/>
        </LinearLayout>

        <!-- Date -->
        <TextView
            android:id="@+id/tv_created_at"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_dim"
            android:textSize="11sp"
            android:layout_marginStart="12dp"
            tools:text="15/01/2024"/>

    </LinearLayout>

    <!-- Đường kẻ Divider nằm dưới cùng -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginHorizontal="12dp"/>

</LinearLayout>