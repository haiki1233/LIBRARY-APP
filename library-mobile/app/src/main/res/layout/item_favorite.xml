<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Cover image -->
        <androidx.cardview.widget.CardView
            android:layout_width="80dp"
            android:layout_height="112dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="6dp">

            <ImageView
                android:id="@+id/iv_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@drawable/placeholder_cover"/>
        </androidx.cardview.widget.CardView>

        <!-- Story info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_background"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.2"
                tools:text="Tên truyện dài dài dài"/>

            <!-- Author -->
            <TextView
                android:id="@+id/tv_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                tools:text="Tác giả ABC"/>

            <!-- Genres -->
            <TextView
                android:id="@+id/tv_genres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_dim"
                android:textSize="11sp"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Tiên hiệp • Huyền huyễn"/>

            <!-- Rating + Chapters row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface_dim"
                    android:textSize="12sp"
                    tools:text="⭐ 4.5"/>

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginHorizontal="6dp"
                    android:background="@color/on_surface_dim"
                    android:backgroundTint="@color/on_surface_dim"/>

                <TextView
                    android:id="@+id/tv_chapters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface_dim"
                    android:textSize="12sp"
                    tools:text="128 chương"/>

                <!-- Spacer -->
                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <!-- Status badge -->
                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="3dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_background"
                    tools:text="Full"
                    tools:background="@drawable/bg_badge_completed"/>
            </LinearLayout>

            <!-- Updated + Saved dates -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tv_updated_at"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/on_surface_dim"
                    android:textSize="11sp"
                    tools:text="Cập nhật: 15/01/2024"/>

                <TextView
                    android:id="@+id/tv_saved_at"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface_dim"
                    android:textSize="11sp"
                    tools:text="Đã lưu: 10/01/2024"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Remove button -->
        <ImageButton
            android:id="@+id/btn_remove"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top"
            android:src="@drawable/ic_close"
            app:tint="@color/on_surface_dim"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Bỏ yêu thích"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>