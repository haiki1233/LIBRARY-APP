<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#E05555"
                android:endColor="#C94444"
                android:angle="0"
                android:type="linear"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <!-- Disabled state -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#3A3A55"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF6B6B"
                android:endColor="#E05555"
                android:angle="0"
                android:type="linear"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</selector>